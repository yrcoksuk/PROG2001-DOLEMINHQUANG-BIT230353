#include <stdio.h>

int main() {
    float a, b;
    printf("Nhap a: "); scanf("%f", &a);
    printf("Nhap b: "); scanf("%f", &b);

    if (a == 0) {
        if (b == 0)
            printf("Phuong trinh co vo so nghiem\n");
        else
            printf("Phuong trinh vo nghiem\n");
    } else {
        // ax + b = 0  =>  x = -b / a
        printf("Nghiem: x = %.4f\n", -b / a);
    }

    return 0;
}